// ============================================================
// Elite Hub — Prisma Schema
// Version: 1.0
// Phase 1 — Full Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ============================================================
// ENUMS
// ============================================================

enum RoleName {
  CUSTOMER
  RESELLER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  BONUS
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentGateway {
  PAYSTACK
  MONNIFY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

enum OrderType {
  AIRTIME
  DATA
  ELECTRICITY
  TV
  ESIM
  SMS_CREDIT
}

enum ProviderType {
  VTU
  SMS
  ESIM
  PAYMENT
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum SupportSource {
  AI_CHAT
  WHATSAPP
}

enum SupportStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum MessageSenderType {
  USER
  AI
  AGENT
}

enum SenderIdStatus {
  DEFAULT
  ACTIVE
  INACTIVE
}

enum SenderIdRequestStatus {
  PENDING
  ADMIN_APPROVED
  SUBMITTED_TO_CARRIER
  ACTIVE
  REJECTED
}

enum EsimOrderStatus {
  PENDING
  PROCESSING
  QR_DELIVERED
  ACTIVATED
  FAILED
  REFUNDED
  DISPUTED
}

enum ReconciliationStatus {
  PENDING
  PROCESSING
  RESOLVED
  FAILED
}

enum RoleUpgradeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

// ============================================================
// 1.1 — IDENTITY & AUTH
// ============================================================

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        RoleName @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  users               User[]
  pricingRules        PricingRule[]
  roleUpgradeRequests RoleUpgradeRequest[] @relation("RequestedRole")

  @@map("roles")
}

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId          String     @map("role_id") @db.Uuid
  firstName       String     @map("first_name") @db.VarChar(100)
  lastName        String     @map("last_name") @db.VarChar(100)
  email           String     @unique @db.VarChar(255)
  phone           String     @unique @db.VarChar(20)
  passwordHash    String?    @map("password_hash") @db.Text
  referralCode    String     @unique @map("referral_code") @db.VarChar(20)
  referredBy      String?    @map("referred_by") @db.Uuid
  isEmailVerified Boolean    @default(false) @map("is_email_verified")
  googleId        String?    @unique @map("google_id") @db.VarChar(255)
  status          UserStatus @default(ACTIVE)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  role                 Role                 @relation(fields: [roleId], references: [id])
  referrer             User?                @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals            User[]               @relation("UserReferrals")
  wallet               Wallet?
  refreshTokens        RefreshToken[]
  paymentTransactions  PaymentTransaction[]
  orders               Order[]
  referralsMade        Referral[]           @relation("ReferrerUser")
  referralReceived     Referral?            @relation("ReferredUser")
  notifications        Notification[]
  supportConversations SupportConversation[]
  apiKeys              ApiKey[]
  smsWallet            SmsWallet?
  smsCampaigns         SmsCampaign[]
  senderIds            SenderId[]
  senderIdRequests     SenderIdRequest[]
  esimOrders           EsimOrder[]
  auditLogs            AuditLog[]           @relation("AuditActor")
  roleUpgradeRequests  RoleUpgradeRequest[] @relation("UpgradeRequester")
  reviewedUpgrades     RoleUpgradeRequest[] @relation("UpgradeReviewer")

  @@index([email])
  @@index([phone])
  @@index([referralCode])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Text
  userAgent String?   @map("user_agent") @db.Text
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ============================================================
// 1.2 — WALLET & FINANCIAL LEDGER
// ============================================================

model Wallet {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  // spendable balance = balance - lockedBalance
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  // locked during PROCESSING orders — released on SUCCESS/FAILED/REFUNDED
  lockedBalance Decimal  @default(0) @map("locked_balance") @db.Decimal(18, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

// Append-only ledger — never update or delete rows
model WalletTransaction {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId        String                  @map("wallet_id") @db.Uuid
  transactionType WalletTransactionType   @map("transaction_type")
  amount          Decimal                 @db.Decimal(18, 2)
  balanceBefore   Decimal                 @map("balance_before") @db.Decimal(18, 2)
  balanceAfter    Decimal                 @map("balance_after") @db.Decimal(18, 2)
  reference       String                  @unique @db.VarChar(100)
  status          WalletTransactionStatus @default(PENDING)
  description     String?                 @db.Text
  metadata        Json?                   @db.JsonB
  // soft link to order — not a FK to avoid circular dependency
  orderId         String?                 @map("order_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([reference])
  @@map("wallet_transactions")
}

model PaymentTransaction {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  gateway          PaymentGateway
  gatewayReference String         @unique @map("gateway_reference") @db.VarChar(255)
  amount           Decimal        @db.Decimal(18, 2)
  status           PaymentStatus  @default(PENDING)
  payload          Json?          @db.JsonB
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([gatewayReference])
  @@map("payment_transactions")
}

// Idempotency guard — prevents double-crediting from webhook retries
model ProcessedWebhook {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway          String   @db.VarChar(50)
  gatewayReference String   @unique @map("gateway_reference") @db.VarChar(255)
  payload          Json?    @db.JsonB
  processedAt      DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@index([gatewayReference])
  @@map("processed_webhooks")
}

// ============================================================
// 1.3 — CATALOG & PRICING
// ============================================================

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  products Product[]

  @@map("categories")
}

model Product {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  name         String   @db.VarChar(255)
  code         String   @unique @db.VarChar(100)
  providerCost Decimal  @map("provider_cost") @db.Decimal(18, 2)
  active       Boolean  @default(true)
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  category     Category      @relation(fields: [categoryId], references: [id])
  pricingRules PricingRule[]
  orderItems   OrderItem[]

  @@index([categoryId])
  @@map("products")
}

// Role-based tier pricing — one row per product per role
model PricingRule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  sellingPrice Decimal  @map("selling_price") @db.Decimal(18, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  product Product @relation(fields: [productId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([productId, roleId])
  @@map("pricing_rules")
}

model Provider {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String       @db.VarChar(100)
  providerType ProviderType @map("provider_type")
  // lower number = higher priority (1 = primary, 2 = failover)
  priority     Int          @default(1)
  active       Boolean      @default(true)
  // encrypted credentials stored here
  config       Json?        @db.JsonB
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  orders             Order[]
  providerHealth     ProviderHealth?
  reconciliationJobs OrderReconciliationJob[]

  @@map("providers")
}

// Circuit breaker state — 5 consecutive failures = unhealthy, 5min cooldown
model ProviderHealth {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId          String    @unique @map("provider_id") @db.Uuid
  isHealthy           Boolean   @default(true) @map("is_healthy")
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastFailureAt       DateTime? @map("last_failure_at") @db.Timestamptz
  cooldownUntil       DateTime? @map("cooldown_until") @db.Timestamptz
  lastCheckedAt       DateTime? @map("last_checked_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider Provider @relation(fields: [providerId], references: [id])

  @@map("provider_health")
}

// ============================================================
// 1.4 — ORDERS & RECONCILIATION
// ============================================================

model Order {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String      @map("user_id") @db.Uuid
  providerId           String?     @map("provider_id") @db.Uuid
  orderType            OrderType   @map("order_type")
  amount               Decimal     @db.Decimal(18, 2)
  // Snapshots frozen at order creation — never recalculated from live pricing
  providerCostSnapshot Decimal     @map("provider_cost_snapshot") @db.Decimal(18, 2)
  sellingPriceSnapshot Decimal     @map("selling_price_snapshot") @db.Decimal(18, 2)
  profitSnapshot       Decimal     @map("profit_snapshot") @db.Decimal(18, 2)
  status               OrderStatus @default(PENDING)
  reference            String      @unique @db.VarChar(100)
  providerReference    String?     @map("provider_reference") @db.VarChar(255)
  providerResponse     Json?       @map("provider_response") @db.JsonB
  metadata             Json?       @db.JsonB
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user               User                     @relation(fields: [userId], references: [id])
  provider           Provider?                @relation(fields: [providerId], references: [id])
  orderItems         OrderItem[]
  reconciliationJobs OrderReconciliationJob[]

  @@index([userId])
  @@index([reference])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int     @default(1)
  unitPrice  Decimal @map("unit_price") @db.Decimal(18, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(18, 2)
  metadata   Json?   @db.JsonB

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Async reconciliation for orders stuck in PROCESSING after provider timeout
model OrderReconciliationJob {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String               @map("order_id") @db.Uuid
  providerId    String               @map("provider_id") @db.Uuid
  status        ReconciliationStatus @default(PENDING)
  attempts      Int                  @default(0)
  lastAttemptAt DateTime?            @map("last_attempt_at") @db.Timestamptz
  resolvedAt    DateTime?            @map("resolved_at") @db.Timestamptz
  notes         String?              @db.Text
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order    Order    @relation(fields: [orderId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("order_reconciliation_jobs")
}

// ============================================================
// 1.5 — REFERRALS & ROLE UPGRADES
// ============================================================

// Reward triggers only on first wallet funding >= ₦2,000
model Referral {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerId     String    @map("referrer_id") @db.Uuid
  referredUserId String    @unique @map("referred_user_id") @db.Uuid
  rewardAmount   Decimal   @map("reward_amount") @db.Decimal(18, 2)
  rewarded       Boolean   @default(false)
  rewardedAt     DateTime? @map("rewarded_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  referrer     User @relation("ReferrerUser", fields: [referrerId], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([referrerId])
  @@map("referrals")
}

// Role upgrades are never self-service — always go through admin approval
model RoleUpgradeRequest {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId     String            @map("requester_id") @db.Uuid
  requestedRoleId String            @map("requested_role_id") @db.Uuid
  status          RoleUpgradeStatus @default(PENDING)
  reason          String?           @db.Text
  reviewedBy      String?           @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?         @map("reviewed_at") @db.Timestamptz
  rejectionReason String?           @map("rejection_reason") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  requester     User  @relation("UpgradeRequester", fields: [requesterId], references: [id])
  requestedRole Role  @relation("RequestedRole", fields: [requestedRoleId], references: [id])
  reviewer      User? @relation("UpgradeReviewer", fields: [reviewedBy], references: [id])

  @@index([requesterId])
  @@index([status])
  @@map("role_upgrade_requests")
}

// ============================================================
// 1.6 — SMS PLATFORM
// ============================================================

model SmsWallet {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  credits   BigInt   @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("sms_wallets")
}

model SmsCampaign {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  campaignName        String    @map("campaign_name") @db.VarChar(255)
  // senderId used at time of sending (may differ from requested if pending approval)
  senderId            String    @map("sender_id") @db.VarChar(50)
  messageBody         String    @map("message_body") @db.Text
  totalRecipients     Int       @default(0) @map("total_recipients")
  totalSent           Int       @default(0) @map("total_sent")
  totalFailed         Int       @default(0) @map("total_failed")
  // DRAFT | SCHEDULED | SENDING | COMPLETED | FAILED
  status              String    @default("DRAFT") @db.VarChar(50)
  scheduledAt         DateTime? @map("scheduled_at") @db.Timestamptz
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  // flag set when custom sender ID was pending and default was used instead
  usedDefaultSenderId Boolean   @default(false) @map("used_default_sender_id")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     User         @relation(fields: [userId], references: [id])
  messages SmsMessage[]

  @@index([userId])
  @@map("sms_campaigns")
}

model SmsMessage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String    @map("campaign_id") @db.Uuid
  recipient        String    @db.VarChar(20)
  message          String    @db.Text
  // PENDING | SENT | DELIVERED | FAILED
  deliveryStatus   String    @default("PENDING") @map("delivery_status") @db.VarChar(50)
  providerResponse Json?     @map("provider_response") @db.JsonB
  sentAt           DateTime? @map("sent_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  campaign SmsCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@map("sms_messages")
}

// Every user gets a DEFAULT sender ID immediately on registration
model SenderId {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  senderId  String         @map("sender_id") @db.VarChar(50)
  isDefault Boolean        @default(false) @map("is_default")
  status    SenderIdStatus @default(DEFAULT)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sender_ids")
}

// PENDING → ADMIN_APPROVED → SUBMITTED_TO_CARRIER → ACTIVE (or REJECTED at any gate)
model SenderIdRequest {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String                @map("user_id") @db.Uuid
  requestedSenderId      String                @map("requested_sender_id") @db.VarChar(50)
  status                 SenderIdRequestStatus @default(PENDING)
  rejectionReason        String?               @map("rejection_reason") @db.Text
  // populated if Termii/carrier rejects after SUBMITTED_TO_CARRIER
  carrierRejectionReason String?               @map("carrier_rejection_reason") @db.Text
  reviewedBy             String?               @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime?             @map("reviewed_at") @db.Timestamptz
  submittedToCarrierAt   DateTime?             @map("submitted_to_carrier_at") @db.Timestamptz
  activatedAt            DateTime?             @map("activated_at") @db.Timestamptz
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("sender_id_requests")
}

// ============================================================
// 1.7 — ESIM MARKETPLACE
// ============================================================

model EsimProduct {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country       String   @db.VarChar(100)
  countryCode   String   @map("country_code") @db.VarChar(10)
  packageName   String   @map("package_name") @db.VarChar(255)
  dataAllowance String   @map("data_allowance") @db.VarChar(50)
  validity      String   @db.VarChar(50)
  costPrice     Decimal  @map("cost_price") @db.Decimal(18, 2)
  sellingPrice  Decimal  @map("selling_price") @db.Decimal(18, 2)
  // Airalo package code or equivalent
  providerCode  String?  @map("provider_code") @db.VarChar(100)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  orders EsimOrder[]

  @@index([country])
  @@map("esim_products")
}

// Auto-refund only if status never reached QR_DELIVERED
// QR_DELIVERED + claim = DISPUTED → manual support only
model EsimOrder {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  esimProductId     String          @map("esim_product_id") @db.Uuid
  iccid             String?         @db.VarChar(50)
  // private URL — served through authenticated endpoint only
  qrCodeUrl         String?         @map("qr_code_url") @db.Text
  activationDetails Json?           @map("activation_details") @db.JsonB
  status            EsimOrderStatus @default(PENDING)
  isDisputed        Boolean         @default(false) @map("is_disputed")
  disputeReason     String?         @map("dispute_reason") @db.Text
  providerReference String?         @map("provider_reference") @db.VarChar(255)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user        User        @relation(fields: [userId], references: [id])
  esimProduct EsimProduct @relation(fields: [esimProductId], references: [id])

  @@index([userId])
  @@map("esim_orders")
}

// ============================================================
// 1.8 — NOTIFICATIONS & SUPPORT
// ============================================================

model Notification {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  title     String              @db.VarChar(255)
  body      String              @db.Text
  status    NotificationStatus  @default(PENDING)
  readAt    DateTime?           @map("read_at") @db.Timestamptz
  metadata  Json?               @db.JsonB
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model SupportConversation {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  source    SupportSource
  status    SupportStatus @default(OPEN)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     User             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@index([userId])
  @@map("support_conversations")
}

model SupportMessage {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  senderType     MessageSenderType @map("sender_type")
  message        String            @db.Text
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  conversation SupportConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("support_messages")
}

// ============================================================
// 1.9 — API PLATFORM & AUDIT
// ============================================================

model ApiKey {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  apiKey        String       @unique @map("api_key") @db.Text
  apiSecretHash String       @map("api_secret_hash") @db.Text
  label         String?      @db.VarChar(100)
  webhookUrl    String?      @map("webhook_url") @db.Text
  status        ApiKeyStatus @default(ACTIVE)
  lastUsedAt    DateTime?    @map("last_used_at") @db.Timestamptz

  // Relations
  user      User          @relation(fields: [userId], references: [id])
  usageLogs ApiUsageLog[]

  @@index([userId])
  @@map("api_keys")
}

model ApiUsageLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId     String   @map("api_key_id") @db.Uuid
  endpoint     String   @db.VarChar(255)
  method       String   @db.VarChar(10)
  statusCode   Int      @map("status_code")
  responseTime Int?     @map("response_time")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId])
  @@map("api_usage_logs")
}

// Full audit trail — every sensitive action writes here
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
